{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "kobe",
  "version": "0.0.0",
  "description": "TUI orchestrator for Claude Code (codename)",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --preload @opentui/solid/preload --conditions=browser ./src/cli/index.ts",
    "build": "bun build --target=bun --outdir=dist ./src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:behavior": "vitest run test/behavior --passWithNoTests",
    "lint": "biome check ."
  },
  "dependencies": {
    "@opentui/core": "0.2.4",
    "@opentui/solid": "0.2.4",
    "solid-js": "1.9.10"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.12",
    "node-pty": "1.1.0",
    "typescript": "5.8.2",
    "vitest": "2.1.9"
  },
  "trustedDependencies": []
}
