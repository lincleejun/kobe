refs/
node_modules/
dist/
.kobe/
# Ignore everything under .claude/ except the project-scoped skills
# directory — those need to live in the repo so Claude Code users
# pick them up automatically. (Trailing `/*` instead of `/` lets the
# `!` negation re-include selected children; a bare `.claude/`
# would block all children regardless of later negations.)
.claude/*
!.claude/skills/
!.claude/skills/**
tsconfig.vitest-temp.json
.DS_Store
*.log
.env
.env.local

# packages/branding outputs the rendered assets into docs/assets/brand/
# (committed). Local-only build artefacts inside the package itself
# (Remotion's `out/`, etc.) are ignored via packages/branding/.gitignore.

# autonomous-skill per-sprint worktrees + session state
.worktrees/
.autonomous/
